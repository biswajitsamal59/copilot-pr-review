{
    "name": "copilot-pr-review-task",
    "version": "1.0.0",
    "description": "Azure DevOps extension for automated code reviews using agentic AI tools",
    "main": "task/index.js",
    "scripts": {
        "build": "tsc",
        "test": "npm run build && node --test \"task/tests/L0.js\"",
        "coverage": "npm run build && c8 --reporter=text --reporter=lcov --include=\"task/**/*.js\" --exclude=\"task/tests/**\" --exclude=\"task/scripts/**\" node --test \"task/tests/L0.js\""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/biswajitsamal59/copilot-pr-review.git"
    },
    "keywords": [
        "azure-devops",
        "copilot",
        "code-review",
        "pull-request",
        "ai"
    ],
    "author": "Biswajit",
    "license": "MIT",
    "dependencies": {
        "azure-pipelines-task-lib": "^5.2.10"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "c8": "^11.0.0",
        "typescript": "^6.0.3"
    }
}
